PORT=3000
MCP_SERVER_NAME=criu-mcp-hub
MCP_SERVER_VERSION=0.2.0
MCP_AUTH_MODE=bearer
MCP_API_KEY=change-me-mcp-api-key
ADMIN_API_KEY=change-me-admin-key
ADMIN_SESSION_SECRET=change-me-session-secret
HUB_STATE_FILE=./data/hub-state.json
WORDPRESS_REGISTRY_TOKEN=change-me-wordpress-registry-token
# Si vienes del wp_criu_registry actual, deja este valor para importar ./data/sites.json
# en el primer arranque. Si empiezas de cero, puedes dejarlo vacio.
WORDPRESS_BOOTSTRAP_SITES_FILE=./data/sites.json

# JSON array opcional para bootstrap inicial de Notion.
# Después, las conexiones viven en el state file y se gestionan desde /admin.
NOTION_CONNECTIONS_JSON=[{"alias":"criu_colombia","label":"Criu Colombia","token":"secret_xxx","defaultParentPageId":"00000000-0000-0000-0000-000000000000"},{"alias":"criu_ops","label":"Criu Ops","token":"secret_yyy","defaultParentPageId":"11111111-1111-1111-1111-111111111111"}]

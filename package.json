{
  "name": "mcp-hub",
  "version": "1.0.0",
  "description": "Servidor MCP propio para centralizar multiples conectores y workspaces.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "import:legacy-registry": "node scripts/import-legacy-registry.mjs",
    "smoke:http": "node scripts/smoke-http.mjs"
  },
  "keywords": [
    "mcp",
    "notion",
    "codex",
    "easypanel"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.22.0",
    "@types/express": "^5.0.6",
    "express": "^5.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {}
}
